# Tundra Portal API configuration. Copy to `.env` and adjust.
# The API reads these as environment variables (see services/api/config.py).

# Require this key in the X-API-Key header. Leave empty to disable auth (dev only).
TUNDRA_API_KEY=

# Root of the (separately-provided) data store: historic COGs, SAM weights,
# imagery composites cache. Locally this is the `data` symlink -> /mnt/memory/Tundra.
TUNDRA_DATA=./data

# Datum-corrected historic map footprints (GeoPackage).
TUNDRA_FOOTPRINTS=./map/Yamal-Nenets/map_footprints_wgs84.gpkg

# Directory of warped historic sheet COGs.
TUNDRA_HISTORIC_COG=./data/historic_cog/Yamal-Nenets

# Cache dir for generated satellite composites.
TUNDRA_CACHE=./data/cache

# Where SAM model weights are downloaded/stored (~2.5 GB for vit_h).
TUNDRA_SAM_DIR=./data/models/sam

# Reject ROI requests larger than this (km^2).
TUNDRA_MAX_ROI_KM2=2500

# PROJ data dir — only needed if using a conda GDAL; pip pyproj bundles its own.
# PROJ_DATA=/path/to/share/proj

# Frontend dev proxy target (used by web/vite.config.ts).
# TUNDRA_API_URL=http://localhost:8000
